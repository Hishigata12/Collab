                    </li>
                <% }) %>
                   <% jobs.forEach(j => { %>
                    <li>
                        <a href="/jobs/<%= j.id %>"><%= j.title %></a>
                        <button class="delete-btn-jobs transparent" data-id="<%= j.id %>">🗑️ </button>
                    </li>
                <% }) %> -->
</body>
</html>