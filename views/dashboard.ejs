<!DOCTYPE html>
<html>

<head> 
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/dashboard.css">
    <%- include('banner'); -%>
    <%- include('dash'); -%>
</head>


<body>
    <div class="title">
        <h1>Dashboard for <%= user.username %></h1>
        <h3>Followers: <%= me.subs %></h3>
    </div>
    <!-- Modal structure -->
     <button onclick="timer(true)"></button>
    <div id="modal" class="modal">
    <div class="modal-content">
        <div class="upload-animation" id="uploadMessage">PDF uploaded successfully!</div>
        <h2 id="upload-timer"></h2>
    </div>
    </div>
    <div class="container">
        <div class="half">
            <div id="form-div">
                <form id="uploadForm" class="upload-form hidden" enctype="multipart/form-data">
                    <h2>Upload PDF</h2>
                    <input type="text" name="title" placeholder="Enter Manuscript Title" required />
                    <input type="file" name="pdf" accept="application/pdf" required />
                    <input type="text" name="authors" placeholder="Comma-separated Authors" required />
                    <input type="text" name="unis" placeholder="Comma-separated Universities" />
                    <textarea name="description" id="study-desc" rows="5"
                          maxlength="512" placeholder="Study Description"></textarea>
                    <div id="char-count">512 characters remaining</div>
                    <label for="study-type">Choose a publication type:</label>
                    <select id="study-type" name="type">
                        <option value='1'>Original Manuscript</option>
                        <option value='2'>Methodology Paper</option>
                        <option value="3">Subject Review</option>
                        <option value="4">Study Replication</option>
                    </select>
                    <input type="text" name="tags" placeholder="Comma-separated tags, 8 max"><br>
                    <div id="replication" class="hidden">
                    <h3>What is the original study ID of this replcation?</h3>
                    <input type="number" min="1" id="original-id" name="original_id" placeholder="ID Number"/>
                    <select name="replication">
                        <option value="0">SUCCESSFUL</option>
                        <option value="1">PARTIAL SUCCESS</option>
                        <option value="2">UNSUCCESSFUL</option>
                    </select>
                    <textarea name="reason" placeholder="Summary"
                        rows="5" maxlength="512" placeholder="Study Description"></textarea>
                    </div>
                    <div id="original-div">
                        <h3>Reproducibility Score (Rate each category from 1-10) More info at:</h3>
                        <input type="number" min="1" max="10" name="cost" placeholder="financial cost">
                        <input type="number" min="1" max="10" name="time" placeholder="study duration">
                        <input type="number" min="1" max="10" name="approval" placeholder="beaurocracy">
                        <input type="number" min="1" max="10" name="expert" placeholder="technical expertise">
                        <input type="number" min="1" max="10"name="availability" placeholder="component availability">
                    </div>
                    <button type="submit">Publish</button>
                    
                </form>
                <form id="jobForm" class="upload-form hidden" enctype="multipart/form-data">
                    <h2>Create Job Listing</h2>
                    <input type="text" name="title" placeholder="Job Listing Name" required />
                    <input type="text" name="desc" placeholder="Enter description" required />
                    <input type="text" name="reqs" placeholder="Enter requirements" />
                    <input type="text" name="contact" placeholder="Enter contact information" required />
                    <label for="pdf">Attach PDF</label>
                    <input type="file" name="pdf" accept="application/pdf">
                    
                    <button type="submit">Submit Job Listing</button>
                   
                </form>
                <form id="edit-pdf-form" class="upload-form hidden" enctype="multipart/form-data">
                    <h3 id="edit-title"></h3>
                    <textarea name="description" id="study-desc" rows="5"
                          maxlength="512" placeholder="Study Description"></textarea>
                    <input type="file" name="pdf" accept="application/pdf"/>
                    <button type="submit">Publish Edits</button>
                    <!-- <div class="upload-animation" id="uploadMessage">Edits processed successfully!</div> -->
                </form>
                 <form id="edit-feedback-form" class="upload-form hidden" enctype="multipart/form-data">
                    <h3 id="edit-title-f"></h3>
                    <textarea name="description" id="study-desc-f" rows="5"
                          maxlength="512" placeholder="Study Description"></textarea>
                    <input type="file" name="pdf" accept="application/pdf"/>
                    <button type="submit">Publish Edits</button>
                    <!-- <div class="upload-animation" id="uploadMessage">Edits processed successfully!</div> -->
                </form>
                <form id="review-form" class="upload-form hidden" enctype="multipart/form-data">
                    <input type="text" name="title" placeholder="Enter title for prepublish review" required />
                    <input type="file" name="pdf" accept="application/pdf" required />
                    <textarea name="description" id="study-desc" rows="5"
                          maxlength="512" placeholder="Study Description and concerns for feedback"></textarea>
                    <div id="char-count">512 characters remaining</div>
                    <label for="study-type">Choose a publication type:</label>
                    <select id="study-type" name="type">
                        <option value='1'>Original Manuscript</option>
                        <option value='2'>Experimental Design</option>
                        <option value="3">Other</option>
                    </select><br>
                    <button type="submit">Post for feedback</button>
                 
                </form>
                <form id="about-me" class="upload-form hidden" enctype="multipart/form-data">
                    <h2>About Me</h2>
                    <input type="text" name="name" id="name-text" placeholder="First name" />
                    <input type="text" name="surname" id="surname-text" placeholder="Last name" />
                    <input type="text" name="email" id="email-text" placeholder="Enter your email" />
                    <textarea name="about" id="about-text" rows="5"
                          maxlength="512" placeholder="Write about yourself"></textarea>
                    <div id="char-count">512 characters remaining</div>
                    <button type="submit">Update Profile</button>
                    
                </form>
                <form id="affiliations" class="upload-form hidden" enctype="multipart/form-data">
                    <h3>Add new affiliation</h3>
                    <input type="text" name="current" id="current-aff" placeholder="Universities, companies, etc" />
                    <h3>Add past affiliation</h3>
                    <input type="text" name="past" id="past-aff" placeholder="Universities, companies, etc" />
                    <h3>Add a link</h3>
                    <input type="text" name="link" id="link-aff" placeholder="Website, social, git, etc" />
                    <button type="submit">Add</button>
                </form>
                  <form id="update-profile" class="upload-form hidden" enctype="multipart/form-data">
                    <h3>Current role or location</h3>
                    <input type="text" name="location" id="badge-location" placeholder="University, Company, Post-doc, Engineer, etc" />
                    <h3>Website</h3>
                    <input type="text" name="site" id="badge-site" placeholder="Personal site, github, IG, etc" />
                    <h3>Profile Picture</h3>
                    <input type="file" name="avatar" accept="application/jpg" />
                    <button type="submit">Update</button>
                </form>
            </div>
            <h2>Articles Published</h2>
            <ul class="upload-list" id="pdf-list">
          
            </ul>
            <h2>Manuscripts/Experimental Plans for Review</h2>
            <ul class="upload-list" id="prepublish-list">
     
            </ul>
            <h2>Job Listings</h2>
            <ul class="upload-list" id="job-postings">
             
            </ul>
        </div>
        <div class="half">
                <div id="pdf-preview" style="display:none; width:75%; height:auto; border:1px solid gray;">
                    <canvas id="pdf-canvas" style="width:100%;"></canvas>
                </div>
                <h3> Current Affilliations</h3>
                <div id="current-div"></div>
                <h3> Past Affiliations</h3>
                <div id="past-div"></div>
                <h3> Links </h3>
                <div id="link-div"></div>
                <div class="main-container">
                <div class="media-box">
                    <h3>Featured Video</h3>
                    <iframe src="https://www.youtube.com/embed/dQw4w9WgXcQ" allowfullscreen></iframe>

                    <h3>Latest Image</h3>
                    <img src="/images/launch2.jpg" width="400px" alt="Latest Image">
                </div>
                </div>
        </div>
    </div>
    <%- include('message') -%>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        const pdfs = <%- JSON.stringify(pdf) %>;
        const reviews = <%- JSON.stringify(review) %>;
        const jobs = <%- JSON.stringify(jobs) %>;
        const user = <%- JSON.stringify(user) %>;
        const caff = <%- JSON.stringify(caff) %>;
        const paff = <%- JSON.stringify(paff) %>;
        const laff = <%- JSON.stringify(laff) %>;
    </script>
